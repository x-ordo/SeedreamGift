generator client {
  provider = "prisma-client-js"
  output   = "../src/shared/prisma/generated/client"
}

datasource db {
  provider = "sqlserver"
}

// ============================================
//  User — 회원
// ============================================
model User {
  id                Int       @id @default(autoincrement()) @map("Id")
  email             String    @unique @db.VarChar(100) @map("Email")
  password          String    @db.VarChar(60) @map("Password")
  name              String?   @db.NVarChar(50) @map("Name")
  phone             String?   @unique @db.VarChar(15) @map("Phone")
  zipCode           String    @default("") @db.VarChar(5) @map("ZipCode")
  address           String    @default("") @db.NVarChar(200) @map("Address")
  addressDetail     String    @default("") @db.NVarChar(200) @map("AddressDetail")
  role              String    @default("USER") @db.VarChar(10) @map("Role")
  kycStatus         String    @default("NONE") @db.VarChar(10) @map("KycStatus")
  kycData           String?   @db.NVarChar(1000) @map("KycData") // AES-256 encrypted JSON — needs ~2x plaintext size
  customLimitPerTx  Decimal?  @db.Decimal(12, 0) @map("CustomLimitPerTx")
  customLimitPerDay Decimal?  @db.Decimal(12, 0) @map("CustomLimitPerDay")
  emailNotification Boolean   @default(true) @map("EmailNotification")
  pushNotification  Boolean   @default(true) @map("PushNotification")
  partnerTier        String?   @db.VarChar(10) @map("PartnerTier")
  totalTradeInVolume Decimal?  @db.Decimal(12, 0) @map("TotalTradeInVolume")
  partnerSince       DateTime? @map("PartnerSince")
  bankName           String?   @db.NVarChar(15) @map("BankName")
  bankCode           String?   @db.VarChar(4) @map("BankCode")
  accountNumber      String?   @db.VarChar(100) @map("AccountNumber")
  accountHolder      String?   @db.NVarChar(15) @map("AccountHolder")
  bankVerifiedAt     DateTime? @map("BankVerifiedAt")
  verifyAttemptCount Int       @default(0) @map("VerifyAttemptCount") @db.TinyInt
  failedLoginAttempts Int       @default(0) @map("FailedLoginAttempts") @db.TinyInt
  lockedUntil         DateTime? @map("LockedUntil")
  lastLoginAt         DateTime? @map("LastLoginAt")
  passwordResetToken  String?   @db.VarChar(64) @map("PasswordResetToken")
  passwordResetExpiry DateTime? @map("PasswordResetExpiry")
  mfaEnabled          Boolean   @default(false) @map("MfaEnabled")
  totpSecret          String?   @db.VarChar(200) @map("TotpSecret") // AES-256 encrypted TOTP secret
  kycVerifiedBy       String?   @db.VarChar(15) @map("KycVerifiedBy")
  kycVerifiedByAdminId Int?     @map("KycVerifiedByAdminId")
  createdAt         DateTime  @default(now()) @map("CreatedAt")
  updatedAt         DateTime  @updatedAt @map("UpdatedAt")
  deletedAt         DateTime? @map("DeletedAt")

  orders        Order[]
  tradeIns      TradeIn[]
  cart          CartItem[]
  refreshTokens RefreshToken[]
  sentGifts     Gift[]     @relation("SentGifts")
  receivedGifts Gift[]     @relation("ReceivedGifts")
  auditLogs         AuditLog[]
  inquiries         Inquiry[]
  answeredInquiries Inquiry[] @relation("InquiryAnswerer")

  @@index([role], map: "IX_Users_Role")
  @@index([kycStatus], map: "IX_Users_KycStatus")
  @@index([deletedAt], map: "IX_Users_DeletedAt")
  @@map("Users")
}

// ============================================
//  RefreshToken — JWT 리프레시 토큰
// ============================================
model RefreshToken {
  id        Int      @id @default(autoincrement()) @map("Id")
  token     String   @db.VarChar(400) @map("Token")
  userId    Int      @map("UserId")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("ExpiresAt")
  userAgent String?  @db.VarChar(256) @map("UserAgent")
  ipAddress String?  @db.VarChar(45) @map("IpAddress")
  createdAt DateTime @default(now()) @map("CreatedAt")

  @@index([userId], map: "IX_RefreshTokens_UserId")
  @@unique([token], map: "UQ_RefreshTokens_Token")
  @@index([expiresAt], map: "IX_RefreshTokens_ExpiresAt")
  @@map("RefreshTokens")
}

// ============================================
//  Brand — 브랜드 마스터
// ============================================
model Brand {
  code        String    @id @db.VarChar(20) @map("Code")
  name        String    @unique @db.NVarChar(20) @map("Name")
  color       String?   @db.VarChar(7) @map("Color")
  order       Int       @default(99) @map("Order") @db.SmallInt
  description String?   @db.NVarChar(100) @map("Description")
  imageUrl    String?   @db.VarChar(300) @map("ImageUrl")
  isActive    Boolean   @default(true) @map("IsActive")
  pinConfig   String?   @db.VarChar(300) @map("PinConfig")
  createdAt   DateTime  @default(now()) @map("CreatedAt")
  updatedAt   DateTime  @updatedAt @map("UpdatedAt")
  deletedAt   DateTime? @map("DeletedAt")

  products Product[]

  @@map("Brands")
}

// ============================================
//  Product — 상품 (상품권 권종)
// ============================================
model Product {
  id           Int       @id @default(autoincrement()) @map("Id")
  brandCode    String    @db.VarChar(20) @map("BrandCode")
  brandRel     Brand?    @relation(fields: [brandCode], references: [code], onDelete: NoAction, onUpdate: Cascade)
  name         String    @db.NVarChar(30) @map("Name")
  description  String?   @db.NVarChar(200) @map("Description")
  price        Decimal   @db.Decimal(10, 0) @map("Price")
  discountRate Decimal   @default(0) @db.Decimal(5, 2) @map("DiscountRate")
  buyPrice     Decimal   @db.Decimal(10, 0) @map("BuyPrice")
  tradeInRate  Decimal   @default(0) @db.Decimal(5, 2) @map("TradeInRate")
  allowTradeIn Boolean   @default(false) @map("AllowTradeIn")
  imageUrl     String?   @db.VarChar(300) @map("ImageUrl")

  isActive     Boolean   @default(true) @map("IsActive")
  type         String    @default("PHYSICAL") @db.VarChar(10) @map("Type") // PHYSICAL, DIGITAL, ENVELOPE
  shippingMethod String  @default("DELIVERY") @db.VarChar(10) @map("ShippingMethod") // NONE, DELIVERY, PICKUP, BOTH
  createdAt    DateTime  @default(now()) @map("CreatedAt")
  updatedAt    DateTime  @updatedAt @map("UpdatedAt")
  deletedAt    DateTime? @map("DeletedAt")

  orderItems   OrderItem[]
  cartItems    CartItem[]
  voucherCodes VoucherCode[]
  tradeIns     TradeIn[]

  @@index([isActive], map: "IX_Products_IsActive")
  @@index([brandCode, isActive], map: "IX_Products_BrandCode_IsActive")
  @@index([brandCode, isActive, deletedAt], map: "IX_Products_BrandCode_Active_Deleted")
  @@index([isActive, price], map: "IX_Products_IsActive_Price")
  @@map("Products")
}

// ============================================
//  VoucherCode — PIN 재고
// ============================================
model VoucherCode {
  id           Int       @id @default(autoincrement()) @map("Id")
  productId    Int       @map("ProductId")
  product      Product   @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: Cascade)
  pinCode      String    @db.VarChar(100) @map("PinCode")
  pinHash      String    @unique @db.VarChar(64) @map("PinHash")
  status       String    @default("AVAILABLE") @db.VarChar(10) @map("Status")
  securityCode String?   @db.VarChar(100) @map("SecurityCode")
  giftNumber   String?   @db.VarChar(100) @map("GiftNumber")
  orderId      Int?      @map("OrderId")
  order        Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  soldAt       DateTime? @map("SoldAt")
  usedAt       DateTime? @map("UsedAt")
  expiredAt    DateTime? @map("ExpiredAt")
  createdAt    DateTime  @default(now()) @map("CreatedAt")
  updatedAt    DateTime  @updatedAt @map("UpdatedAt")

  @@index([productId, status], map: "IX_VoucherCodes_ProductId_Status")
  @@index([productId, status, id], map: "IX_VoucherCodes_ProductId_Status_Id")
  @@index([orderId], map: "IX_VoucherCodes_OrderId")
  @@index([status], map: "IX_VoucherCodes_Status")
  @@map("VoucherCodes")
}

// ============================================
//  Order — 주문
// ============================================
model Order {
  id            Int      @id @default(autoincrement()) @map("Id")
  orderCode     String?  @db.VarChar(20) @map("OrderCode")
  userId        Int      @map("UserId")
  user          User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: Cascade)
  totalAmount   Decimal  @db.Decimal(12, 0) @map("TotalAmount")
  status        String   @default("PENDING") @db.VarChar(12) @map("Status")
  paymentMethod String?  @db.VarChar(15) @map("PaymentMethod")

  paymentKey      String?  @db.VarChar(64) @map("PaymentKey")
  idempotencyKey  String?  @db.VarChar(36) @map("IdempotencyKey")

  // Shipping Info
  shippingMethod  String?  @db.VarChar(10) @map("ShippingMethod")
  recipientName   String?  @db.NVarChar(10) @map("RecipientName")
  recipientPhone  String?  @db.VarChar(15) @map("RecipientPhone")
  recipientAddr   String?  @db.NVarChar(100) @map("RecipientAddr")
  recipientZip    String?  @db.VarChar(5) @map("RecipientZip")

  // Cash Receipt (현금영수증)
  cashReceiptType   String?  @db.VarChar(10) @map("CashReceiptType") // PERSONAL, BUSINESS, NO_RECEIPT
  cashReceiptNumber String?  @db.VarChar(20) @map("CashReceiptNumber")

  createdAt       DateTime @default(now()) @map("CreatedAt")
  updatedAt       DateTime @updatedAt @map("UpdatedAt")

  items        OrderItem[]
  voucherCodes VoucherCode[]
  gift         Gift?
  refund       Refund?
  payments     Payment[]

  @@index([userId, createdAt], map: "IX_Orders_UserId_CreatedAt")
  @@index([userId, status, createdAt], map: "IX_Orders_UserId_Status_CreatedAt")
  @@index([status], map: "IX_Orders_Status")
  @@index([createdAt], map: "IX_Orders_CreatedAt")
  @@index([idempotencyKey], map: "IX_Orders_IdempotencyKey")
  @@index([orderCode], map: "IX_Orders_OrderCode")
  @@map("Orders")
}

// ============================================
//  OrderItem — 주문 항목
// ============================================
model OrderItem {
  id        Int     @id @default(autoincrement()) @map("Id")
  orderId   Int     @map("OrderId")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int     @map("ProductId")
  product   Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: Cascade)
  quantity  Int     @map("Quantity") @db.SmallInt
  price     Decimal @db.Decimal(10, 0) @map("Price")

  @@index([orderId], map: "IX_OrderItems_OrderId")
  @@index([productId], map: "IX_OrderItems_ProductId")
  @@map("OrderItems")
}

// ============================================
//  TradeIn — 매입
// ============================================
model TradeIn {
  id           Int      @id @default(autoincrement()) @map("Id")
  userId       Int      @map("UserId")
  user         User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: Cascade)
  productId    Int      @map("ProductId")
  product      Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: Cascade)

  productName  String?  @db.NVarChar(30) @map("ProductName")
  productBrand String?  @db.NVarChar(10) @map("ProductBrand")
  productPrice Decimal? @db.Decimal(10, 0) @map("ProductPrice")
  quantity     Int      @default(1) @map("Quantity") @db.SmallInt

  pinCode       String? @db.VarChar(100) @map("PinCode")
  pinHash       String? @db.VarChar(64) @map("PinHash")
  securityCode  String? @db.VarChar(100) @map("SecurityCode")
  giftNumber    String? @db.VarChar(100) @map("GiftNumber")
  bankName      String? @db.NVarChar(15) @map("BankName")
  accountNum    String? @db.VarChar(100) @map("AccountNum")
  accountHolder String? @db.NVarChar(10) @map("AccountHolder")
  payoutAmount  Decimal @db.Decimal(10, 0) @map("PayoutAmount")
  status        String  @default("REQUESTED") @db.VarChar(10) @map("Status")
  adminNote     String? @db.NVarChar(500) @map("AdminNote")

  senderName     String?   @db.NVarChar(10) @map("SenderName")
  senderPhone    String?   @db.VarChar(15) @map("SenderPhone")
  senderEmail    String?   @db.VarChar(50) @map("SenderEmail")
  shippingMethod String?   @db.VarChar(10) @map("ShippingMethod")
  shippingDate   DateTime? @map("ShippingDate")
  arrivalDate    DateTime? @map("ArrivalDate")
  message        String?   @db.NVarChar(200) @map("Message")

  createdAt DateTime @default(now()) @map("CreatedAt")
  updatedAt DateTime @updatedAt @map("UpdatedAt")

  @@index([userId, createdAt], map: "IX_TradeIns_UserId_CreatedAt")
  @@index([productId], map: "IX_TradeIns_ProductId")
  @@index([status], map: "IX_TradeIns_Status")
  @@index([status, createdAt], map: "IX_TradeIns_Status_CreatedAt")
  @@index([pinHash], map: "IX_TradeIns_PinHash")
  @@map("TradeIns")
}

// ============================================
//  CartItem — 장바구니
// ============================================
model CartItem {
  id        Int      @id @default(autoincrement()) @map("Id")
  userId    Int      @map("UserId")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int      @map("ProductId")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1) @map("Quantity") @db.SmallInt
  createdAt DateTime @default(now()) @map("CreatedAt")
  updatedAt DateTime @updatedAt @map("UpdatedAt")

  @@unique([userId, productId], map: "UQ_CartItems_UserId_ProductId")
  @@index([userId], map: "IX_CartItems_UserId")
  @@map("CartItems")
}

// ============================================
//  KycVerifySession — 1원 인증 세션 (인메모리 → DB 이관)
// ============================================
model KycVerifySession {
  id             Int      @id @default(autoincrement()) @map("Id")
  verifyTrNo     String   @unique @db.VarChar(30) @map("VerifyTrNo")
  verifyTrDt     String   @db.VarChar(10) @map("VerifyTrDt")
  bankCode       String   @db.VarChar(4) @map("BankCode")
  bankName       String   @db.NVarChar(15) @map("BankName")
  accountNumber  String   @db.VarChar(200) @map("AccountNumber") // AES-256 ciphertext: IV(32hex)+:+cipher(32+hex) ≥ 65 chars
  accountHolder  String   @db.NVarChar(10) @map("AccountHolder")
  isVerified     Boolean  @default(false) @map("IsVerified") // 인증 확인 여부 (회원가입 연동용)
  expiresAt      DateTime @map("ExpiresAt")
  createdAt      DateTime @default(now()) @map("CreatedAt")

  @@index([expiresAt], map: "IX_KycVerifySessions_ExpiresAt")
  @@map("KycVerifySessions")
}

// ============================================
//  SiteConfig — 동적 설정
// ============================================
model SiteConfig {
  id          Int      @id @default(autoincrement()) @map("Id")
  key         String   @unique @db.VarChar(30) @map("Key")
  value       String   @db.NVarChar(MAX) @map("Value")
  type        String   @db.VarChar(10) @map("Type")
  description String?  @db.NVarChar(100) @map("Description")
  updatedAt   DateTime @updatedAt @map("UpdatedAt")

  @@map("SiteConfigs")
}

// ============================================
//  Notice — 공지사항
// ============================================
model Notice {
  id        Int      @id @default(autoincrement()) @map("Id")
  title     String   @db.NVarChar(100) @map("Title")
  content   String   @db.NVarChar(MAX) @map("Content")
  isActive  Boolean  @default(true) @map("IsActive")
  viewCount Int      @default(0) @map("ViewCount")
  createdAt DateTime @default(now()) @map("CreatedAt")
  updatedAt DateTime @updatedAt @map("UpdatedAt")

  @@index([isActive, createdAt], map: "IX_Notices_IsActive_CreatedAt")
  @@map("Notices")
}

// ============================================
//  Event — 이벤트/프로모션
// ============================================
model Event {
  id          Int      @id @default(autoincrement()) @map("Id")
  title       String   @db.NVarChar(100) @map("Title")
  description String   @db.NVarChar(MAX) @map("Description")
  imageUrl    String?  @db.VarChar(300) @map("ImageUrl")
  startDate   DateTime @map("StartDate")
  endDate     DateTime @map("EndDate")
  isActive    Boolean  @default(true) @map("IsActive")
  isFeatured  Boolean  @default(false) @map("IsFeatured")
  viewCount   Int      @default(0) @map("ViewCount")
  createdAt   DateTime @default(now()) @map("CreatedAt")
  updatedAt   DateTime @updatedAt @map("UpdatedAt")

  @@index([isActive], map: "IX_Events_IsActive")
  @@index([isActive, startDate, endDate], map: "IX_Events_Active_DateRange")
  @@map("Events")
}

// ============================================
//  Faq — 자주 묻는 질문
// ============================================
model Faq {
  id           Int      @id @default(autoincrement()) @map("Id")
  question     String   @db.NVarChar(200) @map("Question")
  answer       String   @db.NVarChar(MAX) @map("Answer")
  category     String   @db.VarChar(20) @map("Category")
  order        Int      @default(99) @map("Order") @db.SmallInt
  isActive     Boolean  @default(true) @map("IsActive")
  helpfulCount Int      @default(0) @map("HelpfulCount")
  createdAt    DateTime @default(now()) @map("CreatedAt")
  updatedAt    DateTime @updatedAt @map("UpdatedAt")

  @@index([category], map: "IX_Faqs_Category")
  @@index([isActive, category, order], map: "IX_Faqs_Active_Category_Order")
  @@map("Faqs")
}

// ============================================
//  Gift — 선물
// ============================================
model Gift {
  id         Int      @id @default(autoincrement()) @map("Id")
  senderId   Int      @map("SenderId")
  sender     User     @relation("SentGifts", fields: [senderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  receiverId Int      @map("ReceiverId")
  receiver   User     @relation("ReceivedGifts", fields: [receiverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orderId    Int       @unique @map("OrderId")
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status     String    @default("SENT") @db.VarChar(10) @map("Status")
  claimedAt  DateTime? @map("ClaimedAt")
  expiresAt  DateTime? @map("ExpiresAt")
  message    String?   @db.NVarChar(200) @map("Message")
  createdAt  DateTime  @default(now()) @map("CreatedAt")

  @@index([senderId], map: "IX_Gifts_SenderId")
  @@index([receiverId, createdAt], map: "IX_Gifts_ReceiverId_CreatedAt")
  @@map("Gifts")
}

// ============================================
//  Inquiry — 1:1 문의
// ============================================
model Inquiry {
  id         Int       @id @default(autoincrement()) @map("Id")
  userId     Int       @map("UserId")
  category   String    @db.VarChar(20) @map("Category")
  subject    String    @db.NVarChar(100) @map("Subject")
  content    String    @db.NVarChar(MAX) @map("Content")
  status     String    @default("PENDING") @db.VarChar(10) @map("Status")
  answer     String?   @db.NVarChar(MAX) @map("Answer")
  answeredAt DateTime? @map("AnsweredAt")
  answeredBy Int?      @map("AnsweredBy")
  createdAt  DateTime  @default(now()) @map("CreatedAt")
  updatedAt  DateTime  @updatedAt @map("UpdatedAt")

  user           User  @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  answeredByUser User? @relation("InquiryAnswerer", fields: [answeredBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, createdAt], map: "IX_Inquiries_UserId_CreatedAt")
  @@index([status], map: "IX_Inquiries_Status")
  @@map("Inquiries")
}

// ============================================
//  Refund — 환불
// ============================================
model Refund {
  id            Int      @id @default(autoincrement()) @map("Id")
  orderId       Int      @unique @map("OrderId")
  order         Order    @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: Cascade)
  amount        Decimal  @db.Decimal(12, 0) @map("Amount")
  reason        String   @db.NVarChar(200) @map("Reason")
  status        String   @default("REQUESTED") @db.VarChar(10) @map("Status")
  processedBy   Int?     @map("ProcessedBy")
  processedAt   DateTime? @map("ProcessedAt")
  adminNote     String?  @db.NVarChar(500) @map("AdminNote")
  createdAt     DateTime @default(now()) @map("CreatedAt")
  updatedAt     DateTime @updatedAt @map("UpdatedAt")

  @@index([status], map: "IX_Refunds_Status")
  @@index([orderId], map: "IX_Refunds_OrderId")
  @@map("Refunds")
}

// ============================================
//  Payment — 결제 (은행 직접 연동)
// ============================================
model Payment {
  id             Int       @id @default(autoincrement()) @map("Id")
  orderId        Int       @map("OrderId")
  order          Order     @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: Cascade)
  method         String    @db.VarChar(20) @map("Method")               // CASH, VIRTUAL_ACCOUNT, DEDICATED_ACCOUNT, OPEN_BANKING
  amount         Decimal   @db.Decimal(12, 0) @map("Amount")
  status         String    @default("PENDING") @db.VarChar(15) @map("Status") // PENDING, CONFIRMED, CANCELLED, REFUNDED
  bankCode       String?   @db.VarChar(4) @map("BankCode")              // 은행코드 (004=KB, 088=신한 등)
  bankName       String?   @db.NVarChar(15) @map("BankName")            // 은행명
  accountNumber  String?   @db.VarChar(30) @map("AccountNumber")        // 가상계좌/전용계좌 번호
  depositorName  String?   @db.NVarChar(15) @map("DepositorName")       // 입금자명
  bankTxId       String?   @db.VarChar(64) @map("BankTxId")             // 은행 거래번호
  confirmedAt    DateTime? @map("ConfirmedAt")                          // 입금 확인일시
  cancelledAt    DateTime? @map("CancelledAt")
  expiresAt      DateTime? @map("ExpiresAt")                            // 가상계좌 입금기한
  failReason     String?   @db.NVarChar(200) @map("FailReason")
  createdAt      DateTime  @default(now()) @map("CreatedAt")
  updatedAt      DateTime  @updatedAt @map("UpdatedAt")

  @@index([orderId], map: "IX_Payments_OrderId")
  @@index([status], map: "IX_Payments_Status")
  @@index([bankTxId], map: "IX_Payments_BankTxId")
  @@map("Payments")
}

// ============================================
//  AuditLog — 감사 로그
// ============================================
// ============================================
//  SmsVerification — Coocon 본인인증 결과
//  PAYAGENCY_DB.SMS_VERIFICATION 구조와 동기화
//  외부 Coocon 서버가 직접 INSERT — 컬럼명 수정 금지
// ============================================
/// @see docs/14_KYC_INTEGRATION.md
model SmsVerification {
  uniqueId    BigInt    @id @default(autoincrement()) @map("_UNIQUEID")
  affiliateId String?   @default("") @db.NVarChar(20)  @map("_AFFILIATE_ID")  // 제휴사 ID
  datetime    DateTime? @default(now()) @db.DateTime    @map("_DATETIME")      // 인증 시각
  bankCode    String?   @default("") @db.NVarChar(5)   @map("_BANKCODE")      // 은행코드
  bankNumber  String?   @default("") @db.NVarChar(17)  @map("_BANKNUMBER")    // 계좌번호
  bankUser    String?   @default("") @db.NVarChar(20)  @map("_BANKUSER")      // 예금주
  birth       String?   @default("") @db.NVarChar(9)   @map("_BIRTH")         // 생년월일
  gender      String?   @default("") @db.NVarChar(2)   @map("_GENDER")        // 성별
  nationality String?   @default("") @db.NVarChar(2)   @map("_NATIONALITY")   // L=내국인, F=외국인
  telco       String?   @default("") @db.NVarChar(3)   @map("_TELCO")         // 통신사
  phone       String?   @default("") @db.NVarChar(12)  @map("_PHONE")         // 휴대폰 번호
  ci          String?   @default("") @db.NVarChar(150) @map("_CI")            // 연계정보(CI) 해시값

  @@index([phone], map: "IX_SMS_VERIFICATION_Phone")
  @@index([ci], map: "IX_SMS_VERIFICATION_CI")
  @@map("SMS_VERIFICATION")
}

model AuditLog {
  id         Int      @id @default(autoincrement()) @map("Id")
  createdAt  DateTime @default(now()) @map("CreatedAt")
  userId     Int?     @map("UserId")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   @db.VarChar(50) @map("Action")
  resource   String   @db.VarChar(30) @map("Resource")
  resourceId String?  @db.VarChar(20) @map("ResourceId")
  method     String?  @db.VarChar(7) @map("Method")
  statusCode Int?     @map("StatusCode") @db.SmallInt
  oldValue   String?  @db.NVarChar(MAX) @map("OldValue")
  newValue   String?  @db.NVarChar(MAX) @map("NewValue")
  ip         String?  @db.VarChar(45) @map("Ip")
  userAgent  String?  @db.VarChar(256) @map("UserAgent")
  isArchived Boolean  @default(false) @map("IsArchived")

  @@index([resource, resourceId], map: "IX_AuditLogs_Resource_ResourceId")
  @@index([userId], map: "IX_AuditLogs_UserId")
  @@index([createdAt], map: "IX_AuditLogs_CreatedAt")
  @@index([action], map: "IX_AuditLogs_Action")
  @@index([isArchived, createdAt], map: "IX_AuditLogs_IsArchived_CreatedAt")
  @@map("AuditLogs")
}
