{
  "name": "seedream-gift-server",
  "version": "2.1.0",
  "scripts": {
    "dev": "nest build && node -e \"require('fs').cpSync('./src/shared/prisma/generated','./dist/src/shared/prisma/generated',{recursive:true,force:true})\" && nest start --watch",
    "build": "nest build && node -e \"require('fs').cpSync('./src/shared/prisma/generated','./dist/src/shared/prisma/generated',{recursive:true,force:true})\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint --fix",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push"
  },
