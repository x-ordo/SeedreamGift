# ============================================================
# W기프트 클라이언트 환경변수
# ============================================================

# API URL (dev proxy 사용 시 생략 가능)
VITE_API_URL=/api/v1

# API 프록시 대상 (dev 서버, 기본: http://localhost:5140)
VITE_API_TARGET=http://localhost:5140

# 관리자 페이지 URL 경로
VITE_ADMIN_URL=/wow_admin_837

# OG 이미지 URL
VITE_OG_IMAGE_URL=/og-image.png

# 사이트 도메인 (Excel export 등에 사용)
VITE_SITE_URL=wowgift.co.kr

# 카카오 지도 JavaScript 키 (도메인: wowgift.co.kr)
VITE_KAKAO_MAP_KEY=your_kakao_javascript_key_here
