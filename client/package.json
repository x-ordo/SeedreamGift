{
  "name": "client",
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "preview": "vite preview",
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "api:generate": "node scripts/strip-api-prefix.mjs swagger-spec.json && openapi-generator-cli generate -i swagger-spec.json -g typescript-axios -o src/api/generated --additional-properties=useSingleRequestParameter=true,withSeparateModelsAndApi=true,apiPackage=api,modelPackage=models",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:prod": "npx playwright test --config=playwright.production.config.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "4.43.0",
    "@tanstack/react-virtual": "^3.13.23",
    "axios": "^1.4.0",
    "daisyui": "^5.5.18",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.575.0",
    "motion": "^12.29.2",
    "react": "^18.2.0",
    "react-daum-postcode": "^4.0.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.1.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.14.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@openapitools/openapi-generator-cli": "^2.28.0",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^16.2.0",
    "jsdom": "^29.0.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^4.4.5",
    "vitest": "^1.6.1"
  }
}
